# ------------------------------------------------------------
# DeutschMaroc — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# ------------------------------------------------------------

# Marketing landing → Google Sheets webhook (Apps Script Web App URL ending in /exec)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Signing-key pair for playback tokens (created via CF API — Stream → signing keys)
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_KEY_PEM=
# Webhook HMAC secret (from CF Stream → webhooks)
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@hmwebs.com

# Public app URL (used for magic-link callbacks, webhooks, email CTAs)
NEXT_PUBLIC_APP_URL=https://deutschmaroc.com

# Optional feature flags
NEXT_PUBLIC_ENABLE_TRANSCRIPTION=false
